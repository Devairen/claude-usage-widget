{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Claude Usage",
  "version": "0.1.0",
  "identifier": "dev.devairen.claude-usage",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Claude Usage",
        "width": 380,
        "height": 560,
        "minWidth": 280,
        "minHeight": 360,
        "resizable": true,
        "decorations": false,
        "transparent": false,
        "shadow": true,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: asset: blob:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  }
}
